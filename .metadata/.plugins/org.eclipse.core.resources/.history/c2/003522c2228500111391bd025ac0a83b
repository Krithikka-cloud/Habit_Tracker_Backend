package com.habittracker.Habittracker.serviceimpl;


import org.springframework.beans.factory.annotation.Autowired;
import com.habittracker.Habittracker.security.JwtService;
import org.springframework.security.crypto.password.PasswordEncoder;

import com.habittracker.Habittracker.entity.User;
import org.springframework.stereotype.Service;

import com.habittracker.Habittracker.DTO.LoginRequest;
import com.habittracker.Habittracker.DTO.RegisterRequest;
import com.habittracker.Habittracker.repository.UserRepository;
import com.habittracker.Habittracker.service.UserService;
import java.util.Optional;

@Service
public class UserServiceImpl implements UserService {

    @Autowired
    private UserRepository userRepository;
    
    @Autowired
    private JwtService jwtService;

    @Override
    public String register(RegisterRequest request) {

        // Check if email already exists
        if (userRepository.existsByEmail(request.getEmail())) {
            return "Email already registered!";
        }

        // Create User object
        User user = new User();

        user.setFullName(request.getFullName());
        user.setEmail(request.getEmail());

        // Encrypt password
        user.setPassword(passwordEncoder.encode(request.getPassword()));

        // Save user
        userRepository.save(user);

        return "Registration Successful!";
    }

    @Override
    public String login(LoginRequest request) {

        Optional<User> optionalUser = userRepository.findByEmail(request.getEmail());

        if (optionalUser.isEmpty()) {
            return "Invalid Email or Password!";
        }

        User user = optionalUser.get();

        if (!passwordEncoder.matches(request.getPassword(), user.getPassword())) {
            return "Invalid Email or Password!";
        }

        String token = jwtService.generateToken(user.getEmail());

        return token;
    }
    
    @Autowired
    private PasswordEncoder passwordEncoder;
    
    @Override
    public String deleteAccount(Long id) {

        if (!userRepository.existsById(id)) {
            return "User Not Found!";
        }

        userRepository.deleteById(id);

        return "Account Deleted Successfully!";
    }
    
    @Autowired
    private UserRepository userRepository;

    @Autowired
    private PasswordEncoder passwordEncoder;

}

